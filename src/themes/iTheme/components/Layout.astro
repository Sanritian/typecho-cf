---
import Base from '@/layouts/Base.astro';
import type { ThemeBaseProps } from '@/lib/theme-props';
import { resolveThemeLayoutTitle } from '@/lib/page-title';
import { getHeaderTitle, getHeaderSubtitle, getNavHtml, getSearchDatasetJson } from './shared';

interface Props extends ThemeBaseProps {
  pageTitle?: string;
  searchPosts?: Array<{ permalink: string; title: string; commentsNum: number; excerpt: string }>;
}

const props = Astro.props;
const { title: pageTitle, fullTitle } = resolveThemeLayoutTitle(
  props.pageTitle,
  props.options.title || 'iTheme',
  props.options.description,
);
const isAjaxCommentMode = props.renderMode === 'comment';
const searchDataset = getSearchDatasetJson({ ...props, posts: props.searchPosts || [] });
---
{isAjaxCommentMode ? (
  <slot />
) : (
  <Base
    title={pageTitle}
    fullTitle={fullTitle}
    options={props.options}
    urls={props.urls}
    user={props.user}
    isLoggedIn={props.isLoggedIn}
  >
    <Fragment slot="head">
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
      <meta http-equiv="X-UA-Compatible" content="ie=edge" />
      <script is:inline>
        (() => {
          try {
            const stored = localStorage.getItem('itheme-color-scheme');
            const systemDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            const theme = stored === 'dark' || stored === 'light' ? stored : (systemDark ? 'dark' : 'light');
            document.documentElement.classList.toggle('theme-dark', theme === 'dark');
            document.documentElement.style.colorScheme = theme === 'dark' ? 'dark' : 'light';
          } catch {}
        })();
      </script>
      <script is:inline define:vars={{
        iThemeSearchDataset: searchDataset,
        iThemeAjax: props.isAjaxRequest ? '1' : '0',
        iThemeRenderMode: props.renderMode || '',
        iThemeSearchApi: '/api/theme/itheme-search',
      }}>
        window.__ITHEME_SEARCH_DATA__ = iThemeSearchDataset;
        window.__ITHEME_AJAX__ = iThemeAjax === '1';
        window.__ITHEME_RENDER_MODE__ = iThemeRenderMode;
        window.__ITHEME_SEARCH_API__ = iThemeSearchApi;
      </script>
      <script type="module" src="/themes/iTheme/assets/main.js"></script>
      <slot name="head" />
    </Fragment>
    <div id="wrap">
      <div id="backdrop"></div>
      <header id="bar" class="hidden">
        <h1>
          <a nohover href={props.urls.siteUrl || '/'}>
            {getHeaderTitle(props)}
            <small>{getHeaderSubtitle(props)}</small>
          </a>
        </h1>
        <Fragment set:html={getNavHtml(props)} />
      </header>
      <section id="search">
        <form id="search-form" method="post" action="./" role="search">
          <input id="search-input" type="text" name="s" class="ins-search-input" placeholder="想要查找什么..." />
          <b id="search-close">×</b>
        </form>
        <div id="search-result"></div>
      </section>
      <a id="Ty" href="#"></a>
      <section id="main">
        <slot />
      </section>
      <div id="tip"></div>
      <div id="TOC"></div>
      <footer>
        <div class="tool Topen">
          <div id="Tsidebar" class="Tbutton">
            <span class="Ticon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30"><path d="M25.095 8.003H4.905a1.437 1.437 0 0 0 0 2.874h20.19a1.437 1.437 0 0 0 0-2.874zM16.927 19.122H4.905a1.437 1.437 0 0 0 0 2.874h12.022a1.437 1.437 0 0 0 0-2.874z"></path></svg></span>
          </div>
          <div id="Tclose" class="Tbutton close">
            <span class="Ticon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30"><path d="M23.563 21.676L16.887 15l6.676-6.676a1.334 1.334 0 0 0-1.887-1.887L15 13.113 8.324 6.438a1.334 1.334 0 0 0-1.887 1.887L13.113 15l-6.676 6.676a1.334 1.334 0 0 0 1.887 1.887L15 16.887l6.676 6.676a1.334 1.334 0 0 0 1.887-1.887z"></path></svg></span>
          </div>
          <div id="Tcomments" class="Tbutton" onclick="if(window.commentlist){window.commentlist();return false;}return false;">
            <span class="Ticon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30"><path d="M14.954 2.667C8.179 2.667 2.667 8.199 2.667 15c0 2.189.568 4.324 1.643 6.188l-1.535 5.201a.673.673 0 0 0 .836.835l5.201-1.534a12.273 12.273 0 0 0 6.142 1.643c6.826 0 12.38-5.533 12.38-12.333-.001-6.801-5.554-12.333-12.38-12.333zM6.872 20.84l-.289-.454A9.965 9.965 0 0 1 5.026 15c0-5.5 4.454-9.974 9.928-9.974C20.48 5.026 24.975 9.5 24.975 15s-4.495 9.974-10.021 9.974a9.888 9.888 0 0 1-5.34-1.557l-.453-.29-3.246.958.957-3.245z"></path></svg></span>
            <span id="tips">0</span>
          </div>
          <div id="Ttop" class="Tbutton">
            <span class="Ticon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30"><path d="M6.378 16.627l7.191-7.191v14.412c0 .728.592 1.32 1.32 1.32s1.32-.592 1.32-1.32V9.217l7.412 7.411c.497.498 1.37.498 1.867 0a1.321 1.321 0 0 0 0-1.867l-9.555-9.555c-.497-.498-1.37-.498-1.867 0L4.511 14.76a1.321 1.321 0 0 0 0 1.867c.497.498 1.37.498 1.867 0z"></path></svg></span>
          </div>
        </div>
        <p><small>Typecho @ iTheme</small></p>
      </footer>
    </div>
  </Base>
)}
